    "@nestjs/typeorm": "^10.0.1",
    "@nestjs/swagger": "^7.1.17",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/schedule": "^4.0.0",
    "typeorm": "^0.3.17",
    "pg": "^8.11.3",
    "nodemailer": "^6.9.7",
    "twilio": "^4.19.3",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "bcryptjs": "^2.4.3",
